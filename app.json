{
  "expo": {
    "name": "Arisole",
    "slug": "arisole",
    "version": "1.0.0",
    "scheme": "arisole",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.stealthgodd.arisole",
      "newArchEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arisole.app",
      "merchantId": "merchant.com.stealthgodd.arisole"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      "expo-video",
      "expo-web-browser",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#8311d4"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      "./plugins/withAndroidCppFix",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.stealthgodd.arisole",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b475d9b2-016d-429b-9861-8a9ce431bcb1"
      }
    }
  }
}