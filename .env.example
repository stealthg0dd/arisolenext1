# ============ Supabase (required for app to run) ============
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_jwt
EXPO_PUBLIC_SUPABASE_REDIRECT_URI=arisole://auth/callback

# ============ Stripe (client-side, mapped in src/constants/config.ts) ============
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============ Gemini (client-side AI Coach, mapped in src/constants/config.ts) ============
EXPO_PUBLIC_GEMINI_API_KEY=

# ============ Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ============
# GEMINI_API_KEY          - Primary AI for video analysis
# ANTHROPIC_API_KEY       - Fallback #2
# OPENAI_API_KEY          - Fallback #3
# STRIPE_SECRET_KEY       - For creating checkout sessions
# STRIPE_WEBHOOK_SECRET   - For webhook signature verification

# ============ Other APIs (for Edge Functions or future features) ============
# VERTEX_*                - Google Vertex AI (alternative to Gemini)
# GOOGLE_PLACES_API_KEY   - For location/places features
